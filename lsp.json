{
  "servers": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ],
      "rootPatterns": ["tsconfig.json", "jsconfig.json", "package.json"]
    },
    "ruby": {
      "command": ["ruby-lsp"],
      "extensions": [".rb", ".rake", ".gemspec", ".ru", ".erb"],
      "rootPatterns": ["Gemfile", ".ruby-version", "Gemfile.lock"]
    },
    "svelte": {
      "command": ["svelteserver", "--stdio"],
      "extensions": [".svelte"],
      "rootPatterns": ["svelte.config.js", "svelte.config.ts", "package.json"]
    },
    "markdown": {
      "command": ["marksman", "server"],
      "extensions": [".md", ".markdown"],
      "rootPatterns": [".marksman.toml"]
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"],
      "rootPatterns": []
    },
    "herb": {
      "command": ["herb-language-server", "--stdio"],
      "extensions": [".erb", ".html.erb"],
      "rootPatterns": []
    },
    "tailwindcss": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [
        ".html",
        ".erb",
        ".html.erb",
        ".css",
        ".scss",
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".svelte"
      ],
      "rootPatterns": ["package.json"]
    }
  }
}
