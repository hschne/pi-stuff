{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--executable-path",
        "/usr/bin/chromium"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--executablePath",
        "/usr/bin/chromium",
        "--no-usageStatistics",
        "--no-performanceCrux"
      ]
    }
  }
}
